        <!-- Available Plugins：https://maven.apache.org/plugins/index.html -->
        <plugins>
            <plugin>
                <!-- Creating an Executable Jar：https://docs.spring.io/spring-boot/docs/current/reference/htmlsingle/#getting-started.first-application.executable-jar
                    Spring Boot Maven Plugin：https://docs.spring.io/spring-boot/docs/current/maven-plugin/reference/htmlsingle/    -->
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
                <configuration>
                    <!-- fork：是否分叉运行进程，3.0.0 移除
                        https://jiangchao.blog.csdn.net/article/details/108880019 -->
                    <!-- <fork>true</fork> -->
                    <!-- 资源热刷新 -->
                    <addResources>true</addResources>
                </configuration>
            </plugin>

            <!-- maven-compiler-plugin
                http://maven.apache.org/plugins/maven-compiler-plugin/ -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <configuration>
                    <!-- http://maven.apache.org/general.html#Compiling-Java-7 -->
                    <source>${maven.compiler.source}</source>
                    <target>${maven.compiler.target}</target>
                    <fork>true</fork>
                    <!-- https://maven.apache.org/plugins/maven-compiler-plugin/examples/compile-using-different-jdk.html -->
                    <compilerVersion>${maven.compiler.compilerVersion}</compilerVersion>
                    <encoding>${project.build.sourceEncoding}</encoding>
                    <compilerArgs>
                        <arg>-Xlint:unchecked</arg>
                    </compilerArgs>
                </configuration>
            </plugin>

            <!-- maven-jar-plugin
                http://maven.apache.org/plugins/maven-jar-plugin/
                https://maven.apache.org/plugins/maven-assembly-plugin/ -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-jar-plugin</artifactId>
                <configuration>
                    <!-- http://maven.apache.org/shared/maven-archiver/index.html -->
                    <archive>
                        <manifest>
                            <addClasspath>true</addClasspath>
                            <useUniqueVersions>false</useUniqueVersions>
                            <classpathPrefix>lib/</classpathPrefix>
                            <mainClass>${basedir}/springboot.EpitomeApplication</mainClass>
                        </manifest>
                    </archive>
                </configuration>
            </plugin>

            <plugin>
                <groupId>org.mybatis.generator</groupId>
                <artifactId>mybatis-generator-maven-plugin</artifactId>
                <version>${mybatis-generator-maven-plugin.version}</version>
                <executions>
                    <execution>
                        <id>Generate MyBatis Artifacts</id>
                        <phase>deploy</phase>
                        <goals>
                            <goal>generate</goal>
                        </goals>
                    </execution>
                </executions>
                <configuration>
                    <configurationFile>${basedir}/src/main/resources/mybatis/generator-config.xml</configurationFile>
                    <!-- <configurationFile>${basedir}/src/main/resources/mybatis/generator-config-dynamicSql.xml</configurationFile>-->
                    <overwrite>false</overwrite>
                    <verbose>true</verbose>
                </configuration>
                <dependencies>
                    <dependency>
                        <groupId>com.mysql</groupId>
                        <artifactId>mysql-connector-j</artifactId>
                        <version>${mysql.version}</version>
                    </dependency>
                </dependencies>
            </plugin>
        </plugins>

        <!-- Resources：指定项目资源位置
                https://maven.apache.org/pom.html#resources -->
        <!-- spring-boot-starter-parent 的 resources
            https://stackoverflow.com/questions/60041457/spring-boot-starter-parent-resources-includes-excludes-explained -->
        <!-- <resources/> -->
    </build>

    <!-- Environment Settings：https://maven.apache.org/pom.html#Environment_Settings -->
    <!-- 仓库：Maven 首先尝试使用指定 artifact 的本地副本。如果本地仓库不存在该 artifact，将尝试从远程仓库下载。
                <repository/> 指定要搜索的备用仓库。Maven 默认会搜索 central(https://repo.maven.apache.org/maven2/) 仓库
                https://maven.apache.org/pom.html#repositories -->
    <repositories>
        <repository>
            <id>central</id>
            <!-- public 是 “聚合版”仓库（包含 central + jcenter 等） -->
            <!-- <url>https://maven.aliyun.com/repository/central</url> -->
            <url>https://maven.aliyun.com/repository/public</url>
            <releases>
                <enabled>true</enabled>
            </releases>
            <snapshots>
                <enabled>true</enabled>
            </snapshots>
        </repository>
    </repositories>

    <!-- 插件仓库：https://maven.apache.org/pom.html#plugin-repositories -->
    <pluginRepositories>
        <pluginRepository>
            <id>aliyunmaven</id>
            <url>https://maven.aliyun.com/repository/public</url>
        </pluginRepository>
    </pluginRepositories>

    <!-- 发布管理：https://maven.apache.org/pom.html#distribution-management -->
    <!-- <distributionManagement/> -->

    <!-- Profiles：项目根据构建环境更改设置
        https://maven.apache.org/pom.html#profiles -->
    <profiles>
        <profile>
            <id>druid</id>
            <properties>
                <profileActive>druid</profileActive>
            </properties>
            <activation>
                <activeByDefault>true</activeByDefault>
            </activation>
        </profile>
        <profile>
            <id>h2</id>
            <properties>
                <profileActive>h2</profileActive>
            </properties>
        </profile>
        <profile>
            <id>hikari</id>
            <properties>
                <profileActive>hikari</profileActive>
            </properties>
        </profile>
    </profiles>
</project>
